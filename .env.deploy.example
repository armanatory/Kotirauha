# Copy to .env.deploy (gitignored) and fill in. Used by scripts/deploy-local.sh.

# --- SSH to the shared VPS ---
SSH_HOST=deploy@204.168.171.29
SSH_PORT=22
SSH_KEY=C:\path\to\your\id_ed25519

# --- GHCR (image push + private-repo clone on the server) ---
IMAGE_OWNER=armanatory
GHCR_PAT=

# --- Provider secrets forwarded into /srv/kotirauha/.env on deploy ---
# (Leave blank to keep whatever is already on the server.)
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=
MAILJET_FROM_NAME=Kotirauha
# Platform admin emails (comma-separated). The owner is always admin even
# without this, but set it to add more operators.
ADMIN_EMAIL=
